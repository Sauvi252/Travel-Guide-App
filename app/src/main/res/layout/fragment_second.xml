<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SecondFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/detailImage"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@android:drawable/ic_menu_gallery" />

        <TextView
            android:id="@+id/detailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/detailImage"
            android:text="Place Name" />

        <TextView
            android:id="@+id/detailState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_launcher_background"
            android:padding="4dp"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/detailName"
            app:layout_constraintStart_toStartOf="parent"
            android:text="State" />

        <com.google.android.material.chip.Chip
            android:id="@+id/safetyBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Safety Score: 8.5/10"
            app:chipIcon="@android:drawable/ic_lock_lock"
            app:chipIconTint="#2E7D32"
            app:layout_constraintTop_toTopOf="@id/detailState"
            app:layout_constraintBottom_toBottomOf="@id/detailState"
            app:layout_constraintStart_toEndOf="@id/detailState" />

        <TextView
            android:id="@+id/detailLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@android:color/darker_gray"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/detailState"
            android:text="Location" />

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/detailLocation" />

        <TextView
            android:id="@+id/labelHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="History"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/divider1" />

        <TextView
            android:id="@+id/detailHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/labelHistory"
            android:text="History details..." />

        <TextView
            android:id="@+id/labelBestTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Best Time: "
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/detailHistory"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/detailBestTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/labelBestTime"
            app:layout_constraintStart_toEndOf="@id/labelBestTime"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="Season" />

        <TextView
            android:id="@+id/labelTiming"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Timing: "
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/labelBestTime"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/detailTiming"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/labelTiming"
            app:layout_constraintStart_toEndOf="@id/labelTiming"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="9AM - 6PM" />

        <TextView
            android:id="@+id/labelFee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Entry Fee: "
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/labelTiming"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/detailFee"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/labelFee"
            app:layout_constraintStart_toEndOf="@id/labelFee"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="Free" />

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/divider2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/detailFee" />

        <TextView
            android:id="@+id/labelNearby"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Nearby Tourist Spots"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/divider2" />

        <TextView
            android:id="@+id/detailNearby"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/labelNearby"
            android:text="Spots list..." />

        <TextView
            android:id="@+id/labelTips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Travel Tips"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/detailNearby" />

        <TextView
            android:id="@+id/detailTips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#D32F2F"
            app:layout_constraintTop_toBottomOf="@id/labelTips"
            android:text="Tips..." />

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/dividerPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/detailTips" />

        <TextView
            android:id="@+id/labelPriceAI"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="AI Price Insights"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/dividerPrice"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/detailPriceAI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="#E8F5E9"
            android:padding="8dp"
            android:text="AI Prediction: Prices likely to drop by 15% next month. Best time to book!"
            android:textColor="#2E7D32"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/labelPriceAI" />

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/dividerEco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/detailPriceAI" />

        <LinearLayout
            android:id="@+id/ecoSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:background="#F1F8E9"
            android:padding="12dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/dividerEco">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_mapmode"
                app:tint="#388E3C" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sustainable Travel Score"
                    android:textStyle="bold"
                    android:textColor="#2E7D32" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="92% Eco-Friendly Destination"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A+"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#388E3C" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/facilitiesLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/detailPriceAI">

            <Button
                android:id="@+id/button_hotels"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Hotels" />

            <Button
                android:id="@+id/button_restaurants"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Food" />
        </LinearLayout>

        <Button
            android:id="@+id/button_map"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="View on Google Map"
            app:layout_constraintTop_toBottomOf="@id/facilitiesLayout" />

        <Button
            android:id="@+id/button_buddy"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Find Travel Buddies for this place"
            app:icon="@android:drawable/ic_menu_myplaces"
            app:layout_constraintTop_toBottomOf="@id/button_map" />

        <Button
            android:id="@+id/buttonSecond"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Back to List"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/button_buddy" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
